    {
      "parameters": {
        "method": "GET",
        "url": "={{ $('Webhook EvoAPI').item.json.body.supabase_url }}/rest/v1/services?select=name,description,price&active=eq.true&limit=30",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headers": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $('Webhook EvoAPI').item.json.body.supabase_service_key }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('Webhook EvoAPI').item.json.body.supabase_service_key }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "node-get-services",
      "name": "Buscar Serviços",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 480]
    },
    {
      "parameters": {
        "jsCode": "// Monta o payload para OpenAI com histórico + contexto\nconst body = $('Webhook EvoAPI').item.json.body;\nconst history = $('Buscar Histórico').item.json;\nconst services = $('Buscar Serviços').item.json;\n\n// Ordena histórico cronologicamente (veio DESC do banco)\nconst historyMsgs = Array.isArray(history)\n  ? [...history].reverse().map(m => ({\n      role: m.from_me ? 'assistant' : 'user',\n      content: m.text,\n    }))\n  : [];\n\n// Contexto de serviços\nconst servicesCtx = Array.isArray(services) && services.length > 0\n  ? '\\n\\nSERVIÇOS DISPONÍVEIS:\\n' + services.map(s =>\n      `- ${s.name}${s.price ? ` (R$ ${s.price})` : ''}${s.description ? `: ${s.description}` : ''}`\n    ).join('\\n')\n  : '';\n\n// Prompt do sistema com qualificações\nconst quals = (body.qualifications ?? []).map((q, i) =>\n  `${i + 1}. Quando o lead ${q.description} → chame move_lead com status \"${q.status_name}\"`\n).join('\\n');\n\nconst systemPrompt = `${body.agent.system_prompt}${servicesCtx}\n\nREGRAS DE QUALIFICAÇÃO:\n${quals || 'Nenhuma qualificação configurada.'}\n\nFERRAMENTAS DISPONÍVEIS:\n- move_lead(status): Use quando o lead demonstrar a condição de qualificação acima. Passe o status_name correto.\n- request_human: Use quando o lead pedir para falar com um humano, reclamar, ou você não souber responder.`;\n\nconst messages = [\n  { role: 'system', content: systemPrompt },\n  ...historyMsgs,\n  { role: 'user', content: body.message },\n];\n\nconst tools = [\n  {\n    type: 'function',\n    function: {\n      name: 'move_lead',\n      description: 'Muda o status/etapa do lead no pipeline com base na qualificação identificada',\n      parameters: {\n        type: 'object',\n        properties: {\n          status: {\n            type: 'string',\n            description: 'O status_name da qualificação que foi identificada'\n          }\n        },\n        required: ['status']\n      }\n    }\n  },\n  {\n    type: 'function',\n    function: {\n      name: 'request_human',\n      description: 'Transfere o atendimento para um humano',\n      parameters: {\n        type: 'object',\n        properties: {},\n        required: []\n      }\n    }\n  }\n];\n\nreturn [\n  {\n    json: {\n      openai_payload: {\n        model: body.agent.model ?? 'gpt-4o-mini',\n        messages,\n        tools,\n        tool_choice: 'auto',\n      },\n      context: body,\n    }\n  }\n];"
      },
      "id": "node-build-prompt",
      "name": "Montar Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 380]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headers": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.context.openai_key }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.openai_payload) }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "node-openai-1",
      "name": "OpenAI — 1ª chamada",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [960, 380]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-tool-call",
              "leftValue": "={{ $json.choices[0].finish_reason }}",
              "rightValue": "tool_calls",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-if-tool",
      "name": "Tem tool_call?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1200, 380]
    },
    {
      "parameters": {
        "jsCode": "// Extrai a tool_call da resposta da OpenAI\nconst choice = $json.choices[0];\nconst toolCall = choice.message.tool_calls[0];\nconst toolName = toolCall.function.name;\nconst toolArgs = JSON.parse(toolCall.function.arguments ?? '{}');\nconst context = $('Montar Prompt').item.json.context;\n\nreturn [\n  {\n    json: {\n      tool_name: toolName,\n      tool_args: toolArgs,\n      tool_call_id: toolCall.id,\n      context,\n    }\n  }\n];"
      },
      "id": "node-parse-tool",
      "name": "Parse Tool Call",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1440, 260]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "is-move-lead",
              "leftValue": "={{ $json.tool_name }}",
              "rightValue": "move_lead",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-if-move",
      "name": "move_lead ou request_human?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1680, 260]
    },
    {
      "parameters": {
        "jsCode": "// Resolve target_stage_id para move_lead via agent_qualifications + agent_actions\nconst ctx = $json.context;\nconst status = $json.tool_args.status;\n\n// Busca action configurada para este status\nconst actions = ctx.qualifications ?? [];\n// Verifica se a etapa atual tem move_to_next_id configurado\nconst targetStageId = ctx.stage.move_to_next_id;\n\nreturn [\n  {\n    json: {\n      ...$json,\n      resolved_stage_id: targetStageId,\n      status,\n    }\n  }\n];"
      },
      "id": "node-resolve-stage",
      "name": "Resolver Stage Destino",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1920, 160]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $json.context.supabase_url }}/rest/v1/leads?id=eq.{{ $json.context.lead.id }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headers": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $json.context.supabase_service_key }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.context.supabase_service_key }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"stage_id\": \"{{ $json.resolved_stage_id }}\", \"updated_at\": \"{{ new Date().toISOString() }}\" }",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "node-move-lead",
      "name": "PATCH lead — mover etapa",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2160, 160]
    },
    {
      "parameters": {
        "jsCode": "// request_human — move para move_to_human_id\nconst ctx = $json.context;\nreturn [\n  {\n    json: {\n      ...$json,\n      resolved_stage_id: ctx.stage.move_to_human_id,\n    }\n  }\n];"
      },
      "id": "node-resolve-human",
      "name": "Resolver Stage Humano",

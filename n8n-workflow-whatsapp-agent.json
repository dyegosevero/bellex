      "id": "node-move-human",
      "name": "PATCH lead — mover p/ humano",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2160, 360]
    },
    {
      "parameters": {
        "jsCode": "// Monta 2ª chamada OpenAI após execução do tool\nconst parseNode = $('Parse Tool Call').item.json;\nconst promptNode = $('Montar Prompt').item.json;\nconst ctx = parseNode.context;\n\n// Reconstrói o array de mensagens adicionando resultado da tool\nconst prevMessages = promptNode.openai_payload.messages;\nconst assistantMsgWithTool = {\n  role: 'assistant',\n  content: null,\n  tool_calls: [\n    {\n      id: parseNode.tool_call_id,\n      type: 'function',\n      function: {\n        name: parseNode.tool_name,\n        arguments: JSON.stringify(parseNode.tool_args),\n      }\n    }\n  ]\n};\nconst toolResultMsg = {\n  role: 'tool',\n  tool_call_id: parseNode.tool_call_id,\n  content: 'ok',\n};\n\nreturn [\n  {\n    json: {\n      openai_payload: {\n        model: ctx.agent.model ?? 'gpt-4o-mini',\n        messages: [...prevMessages, assistantMsgWithTool, toolResultMsg],\n      },\n      context: ctx,\n    }\n  }\n];"
      },

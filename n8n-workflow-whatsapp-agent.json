      "parameters": {
        "jsCode": "// Extrai texto da resposta direta (sem tool_call)\nconst context = $('Montar Prompt').item.json.context;\nconst responseText = $json.choices[0]?.message?.content ?? 'Olá! Como posso ajudar?';\n\nreturn [\n  {\n    json: {\n      response_text: responseText,\n      context,\n    }\n  }\n];"
      },

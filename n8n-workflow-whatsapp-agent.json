    {
      "parameters": {
        "jsCode": "// Extrai texto da resposta (seja da 1ª ou 2ª chamada)\nlet responseText = '';\nconst context = $('Montar Prompt').item.json.context;\n\nif ($json.choices) {\n  responseText = $json.choices[0]?.message?.content ?? '';\n} else {\n  responseText = 'Não foi possível gerar uma resposta no momento.';\n}\n\nreturn [\n  {\n    json: {\n      response_text: responseText,\n      context,\n    }\n  }\n];"
      },
      "id": "node-extract-response-after-tool",
      "name": "Extrair Resposta (pós-tool)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2880, 260]

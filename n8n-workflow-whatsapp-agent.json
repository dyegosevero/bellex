    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $json.context.supabase_url }}/rest/v1/leads?id=eq.{{ $json.context.lead.id }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headers": {
